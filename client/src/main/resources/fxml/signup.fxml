<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.chat.app.controller.SignupController">

    <left>
        <VBox alignment="CENTER" prefWidth="400" spacing="20" styleClass="left-pane">

            <Label styleClass="title-white" text="Join Us" />

            <Label styleClass="subtitle-white" text="Create your account" />

        </VBox>
    </left>

    <center>

        <VBox alignment="CENTER" spacing="15" styleClass="form-pane">

            <Label styleClass="title" text="Sign Up" />

            <TextField fx:id="nameField" promptText="Full Name" styleClass="text-field-modern" />

            <TextField fx:id="emailField" promptText="Email" styleClass="text-field-modern" />

            <PasswordField fx:id="passwordField" promptText="Password" styleClass="text-field-modern" />

            <ComboBox fx:id="genderBox"  promptText="Gender" styleClass="text-field-modern" />

            <TextField fx:id="mobileField" promptText="Mobile Number" styleClass="text-field-modern" />

            <HBox alignment="CENTER" spacing="10">

                <Button onAction="#chooseAvatar" text="Choose Avatar" />

                <Label fx:id="avatarLabel" text="No file selected" />
            </HBox>

            <Button onAction="#signup" styleClass="button-primary" text="Create Account" />

            <Hyperlink onAction="#goToLogin" text="Already have an account?" />

        </VBox>

    </center>

</BorderPane>
